# Application
APP_NAME=医院抢救车药品与物资效期管理系统
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# HTTP 服务
APP_HOST=0.0.0.0
APP_PORT=7080

# Database（本地 PostgreSQL）
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rescue

# Flutter 移动端 API 地址请配置 mobile/.env，不要写入本文件

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Scheduler
INVENTORY_EXPIRY_CRON_HOUR=1
INVENTORY_EXPIRY_CRON_MINUTE=0

# Seed admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin@123456
