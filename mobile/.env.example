# Flutter 移动端 API 配置（后端默认端口 7080）
#
#   flutter run                                          # 使用 .env
#   flutter run --dart-define=ENV_FILE=.env.android.emulator
#   flutter run --dart-define=ENV_FILE=.env.android.device

# --- 本机调试（Windows / iOS 模拟器 / Chrome）---
API_BASE_URL=http://127.0.0.1:7080/api/v1

# --- Android 模拟器 ---
# API_BASE_URL=http://10.0.2.2:7080/api/v1

# --- Android 真机（改为电脑局域网 IP）---
# API_BASE_URL=http://192.168.1.100:7080/api/v1

API_CONNECT_TIMEOUT=15
API_RECEIVE_TIMEOUT=15
